# 数据库配置
# 可选值: prisma (默认) 或 cloudbase
DB_TYPE=prisma

# CloudBase 环境 ID (如果使用 cloudbase 数据库)
# 在 CloudBase 控制台获取: https://tcb.cloud.tencent.com/
CLOUDBASE_ENV_ID=your-env-id-here

# Prisma 数据库 URL (如果使用 prisma 数据库)
DATABASE_URL="file:./dev.db"

# Next.js 配置
NODE_ENV=development
PORT=3000

# 微信登录配置 (微信小程序)
# 在微信公众平台获取: https://mp.weixin.qq.com/
WECHAT_APPID=your-wechat-appid-here
WECHAT_SECRET=your-wechat-secret-here
