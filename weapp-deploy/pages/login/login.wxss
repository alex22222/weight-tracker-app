/**pages/login/login.wxss**/
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ecfdf5 0%, #f0fdfa 50%, #ecfeff 100%);
  padding: 40rpx;
}

.login-wrapper {
  max-width: 600rpx;
  margin: 0 auto;
}

/* Logo区域 */
.logo-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.logo {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.logo-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
}

.logo-subtitle {
  font-size: 28rpx;
  color: #10b981;
  margin-top: 8rpx;
}

/* 功能介绍 */
.features {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.6);
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
}

.feature-icon {
  font-size: 40rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

/* 登录方式切换 */
.login-tabs {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #64748b;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.tab.active {
  background: linear-gradient(135deg, #10b981 0%, #14b8a6 100%);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.3);
}

/* 微信登录区域 */
.wechat-login-section {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  text-align: center;
}

.wechat-login-desc {
  margin-bottom: 48rpx;
}

.desc-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.desc-text {
  display: block;
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

/* 微信登录按钮 */
.btn-wechat {
  background: linear-gradient(135deg, #07c160 0%, #10b981 100%);
  color: white;
  border-radius: 16rpx;
  padding: 36rpx 40rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(7, 193, 96, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-wechat::after {
  border: none;
}

.btn-wechat:active {
  transform: scale(0.98);
}

.wechat-icon {
  width: 48rpx;
  height: 48rpx;
}

/* 静默登录按钮 */
.btn-wechat-silent {
  background: #07c160;
  color: white;
  border-radius: 16rpx;
  padding: 36rpx 40rpx;
  font-size: 34rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 32rpx;
}

.btn-wechat-silent::after {
  border: none;
}

.btn-wechat-silent:active {
  transform: scale(0.98);
}

/* 隐私提示 */
.privacy-notice {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.privacy-notice text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 表单卡片 */
.form-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 32rpx;
  padding: 48rpx 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
}

.form-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
  text-align: center;
  margin-bottom: 12rpx;
}

.form-subtitle {
  font-size: 26rpx;
  color: #64748b;
  text-align: center;
  margin-bottom: 40rpx;
}

/* 错误提示 */
.error-tip {
  background: #fee2e2;
  color: #ef4444;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #fecaca;
}

/* 输入组 */
.input-group {
  display: flex;
  align-items: center;
  background: #f1f5f9;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.input-group:focus-within {
  border-color: #10b981;
  background: #fff;
}

.input-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  opacity: 0.7;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #1e293b;
  background: transparent;
  border: none;
  padding: 0;
}

.input::placeholder {
  color: #94a3b8;
}

/* 表单选项 */
.form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.remember-me {
  font-size: 26rpx;
  color: #64748b;
}

.forgot-link {
  font-size: 26rpx;
  color: #10b981;
  font-weight: 500;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #10b981 0%, #14b8a6 100%);
  color: white;
  border-radius: 16rpx;
  padding: 32rpx 40rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.3);
}

.btn-primary::after {
  border: none;
}

.btn-primary:active {
  transform: scale(0.98);
}

.btn-guest {
  background: transparent;
  color: #94a3b8;
  border: none;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.btn-guest::after {
  border: none;
}

/* 模式切换 */
.mode-switch {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 12rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

.mode-text {
  font-size: 26rpx;
  color: #94a3b8;
}

.mode-link {
  font-size: 26rpx;
  color: #10b981;
  font-weight: 600;
}