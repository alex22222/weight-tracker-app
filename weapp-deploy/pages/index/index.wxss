/* pages/index/index.wxss */

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-bottom: 20rpx;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.header-title {
  flex: 1;
  min-width: 0;
}

.title-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
  display: block;
}

.channel-info {
  font-size: 24rpx;
  color: #10b981;
  margin-top: 8rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.weather-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.8);
  padding: 12rpx 20rpx;
  border-radius: 30rpx;
}

.weather-icon {
  font-size: 32rpx;
}

.weather-temp {
  font-size: 26rpx;
  font-weight: 500;
  color: #475569;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stat-card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.stat-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.stat-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.bg-primary-light {
  background: #d1fae5;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  font-weight: 500;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}

.stat-unit {
  font-size: 24rpx;
  color: #94a3b8;
}

.stat-hint {
  font-size: 22rpx;
  font-weight: 500;
}

.text-success {
  color: #10b981;
}

.text-danger {
  color: #ef4444;
}

.text-tertiary {
  color: #94a3b8;
}

/* 卡片 */
.card {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
}

/* 表单 */
.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
}

.form-item-full {
  grid-column: span 2;
}

.form-label {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1e293b;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-input::after {
  content: '▼';
  font-size: 20rpx;
  color: #94a3b8;
}

/* 按钮 */
.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary[disabled] {
  opacity: 0.5;
}

.btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.mt-3 {
  margin-top: 24rpx;
}

.flex {
  display: flex;
}

.gap-2 {
  gap: 16rpx;
}

.flex-1 {
  flex: 1;
}

/* 图表 */
.chart-container {
  width: 100%;
  height: 400rpx;
  background: #f8fafc;
  border-radius: 16rpx;
  overflow: hidden;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* 分享卡片 */
.share-card {
  background: linear-gradient(135deg, #f0fdf4, #ecfdf5);
  border: 2rpx solid #bbf7d0;
}

.share-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.share-text {
  margin-bottom: 20rpx;
}

.share-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.share-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
}

.btn-share {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 48rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-share::after {
  border: none;
}
