generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WeightEntry {
  id        Int      @id @default(autoincrement())
  weight    Float
  note      String?
  date      DateTime
  createdAt DateTime @default(now())
  userId    Int      // 关联到用户
  user      User     @relation(fields: [userId], references: [id])
}

model User {
  id           Int              @id @default(autoincrement())
  username     String           @unique
  password     String
  gender       String?          // 性别: male, female, other
  avatar       String?          // 头像URL
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  lastLoginAt  DateTime?        // 最后一次登录时间
  weightEntries WeightEntry[]   // 用户的体重记录
  sentMessages Message[]        @relation("SentMessages")      // 发送的消息
  recvMessages Message[]        @relation("ReceivedMessages")  // 接收的消息
  sentFriends  Friend[]         @relation("SentFriends")       // 发送的好友请求
  recvFriends  Friend[]         @relation("ReceivedFriends")   // 接收的好友请求
  
  // 健身频道相关
  ownedChannels    FitnessChannel[] @relation("ChannelOwner")    // 创建的频道
  channelMembers   ChannelMember[]                                 // 加入的频道
  checkIns         CheckIn[]                                       // 打卡记录
  comments         ChannelComment[]                                // 评论
  leaveRequests    LeaveRequest[]                                  // 请假申请
}

model UserSettings {
  id           Int      @id @default(autoincrement())
  height       Float    @default(170)
  targetWeight Float    @default(65)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 消息模型
model Message {
  id         Int       @id @default(autoincrement())
  type       String    // 消息类型: SYSTEM_LOGIN, SYSTEM_PASSWORD, FRIEND_REQUEST, FRIEND_ACCEPT, FRIEND_REJECT, CHANNEL_INVITE
  title      String    // 消息标题
  content    String    // 消息内容
  isRead     Boolean   @default(false)
  createdAt  DateTime  @default(now())
  
  // 关联用户
  fromUserId Int?      // 发送者ID（系统消息可为空）
  fromUser   User?     @relation("SentMessages", fields: [fromUserId], references: [id])
  toUserId   Int       // 接收者ID
  toUser     User      @relation("ReceivedMessages", fields: [toUserId], references: [id])
  
  // 相关数据
  relatedData String?  // 额外数据（JSON格式存储）
}

// 好友关系模型
model Friend {
  id         Int       @id @default(autoincrement())
  status     String    @default("PENDING") // PENDING, ACCEPTED, REJECTED, BLOCKED
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  
  // 关联用户
  fromUserId Int       // 发起者ID
  fromUser   User      @relation("SentFriends", fields: [fromUserId], references: [id])
  toUserId   Int       // 接收者ID
  toUser     User      @relation("ReceivedFriends", fields: [toUserId], references: [id])
  
  @@unique([fromUserId, toUserId])
}

// ==================== 健身拼团频道 ====================

// 健身频道
model FitnessChannel {
  id                 Int       @id @default(autoincrement())
  name               String    // 频道名称
  description        String?   // 频道描述
  status             String    @default("PENDING") // PENDING, ACTIVE, COMPLETED
  startDate          DateTime  // 开始日期
  endDate            DateTime  // 结束日期
  weeklyCheckInCount Int       @default(3) // 每周至少打卡次数
  checkInMinutes     Int       @default(30) // 每次打卡分钟数
  maxLeaveDays       Int       @default(3) // 最多请假天数（0表示不允许请假）
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  
  // 关联
  ownerId     Int       // 创建者ID
  owner       User      @relation("ChannelOwner", fields: [ownerId], references: [id])
  members     ChannelMember[]   // 频道成员
  checkIns    CheckIn[]         // 打卡记录
  comments    ChannelComment[]  // 评论
  leaveRequests LeaveRequest[]  // 请假申请
}

// 频道成员关系
model ChannelMember {
  id          Int       @id @default(autoincrement())
  joinedAt    DateTime  @default(now())
  
  // 关联
  channelId   Int
  channel     FitnessChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([channelId, userId])
}

// 健身打卡记录
model CheckIn {
  id          Int       @id @default(autoincrement())
  checkDate   DateTime  // 打卡日期
  duration    Int       @default(30) // 打卡时长（分钟）
  note        String?   // 备注
  imageUrl    String?   // 打卡图片URL
  createdAt   DateTime  @default(now())
  
  // 关联
  channelId   Int
  channel     FitnessChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@unique([channelId, userId, checkDate]) // 每天只能打卡一次
}

// 频道评论
model ChannelComment {
  id        Int       @id @default(autoincrement())
  content   String    // 评论内容
  createdAt DateTime  @default(now())
  
  // 关联
  channelId Int
  channel   FitnessChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 请假申请
model LeaveRequest {
  id          Int       @id @default(autoincrement())
  startDate   DateTime  // 请假开始日期
  endDate     DateTime  // 请假结束日期
  reason      String?   // 请假原因
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt   DateTime  @default(now())
  
  // 关联
  channelId   Int
  channel     FitnessChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  userId      Int
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}
