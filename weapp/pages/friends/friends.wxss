/* pages/friends/friends.wxss */

/* 头部 */
.header-section {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 24rpx;
  margin-bottom: 30rpx;
}

.header-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.header-content {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: white;
}

.header-subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 8rpx;
}

.add-btn {
  background: white;
  color: #10b981;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 区块 */
.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
}

/* 请求列表 */
.request-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.request-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: white;
  margin-right: 20rpx;
}

.user-detail {
  display: flex;
  flex-direction: column;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.request-type {
  font-size: 24rpx;
  color: #f59e0b;
  margin-top: 4rpx;
}

.friend-since {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.request-actions {
  display: flex;
  gap: 12rpx;
}

.btn-accept {
  background: #d1fae5;
  color: #059669;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.btn-reject {
  background: #f1f5f9;
  color: #64748b;
  border: none;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
  font-size: 26rpx;
}

.request-status {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 好友列表 */
.friend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.friend-item {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 12rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 100%;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 36rpx;
  color: #94a3b8;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f1f5f9;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1e293b;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

.flex-1 {
  flex: 1;
}
