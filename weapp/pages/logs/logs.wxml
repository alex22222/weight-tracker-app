<!--pages/logs/logs.wxml-->
<view class="container">
  <!-- 统计概览 -->
  <view class="card">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-number">{{entries.length}}</text>
        <text class="stat-desc">总记录数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number" wx:if="{{entries.length > 0}}">{{entries[entries.length-1].weight.toFixed(1)}}</text>
        <text class="stat-number" wx:else>--</text>
        <text class="stat-desc">首次记录</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-number" wx:if="{{entries.length > 0}}">{{entries[0].weight.toFixed(1)}}</text>
        <text class="stat-number" wx:else>--</text>
        <text class="stat-desc">最新记录</text>
      </view>
    </view>
  </view>

  <!-- 记录列表 -->
  <view class="card" wx:if="{{entries.length > 0}}">
    <view class="section-title">
      <text class="title-icon">📋</text>
      <text>历史记录</text>
    </view>
    
    <view class="entry-list">
      <view class="entry-item" wx:for="{{entries}}" wx:key="id">
        <view class="entry-main">
          <view class="entry-left">
            <view class="entry-date">{{item.formattedDate}}</view>
            <view class="entry-note" wx:if="{{item.note}}">{{item.note}}</view>
          </view>
          
          <view class="entry-right">
            <view class="entry-weight">{{item.weight.toFixed(1)}} <text class="unit">kg</text></view>
            
            <view class="entry-change {{item.change > 0 ? 'text-danger' : (item.change < 0 ? 'text-success' : 'text-tertiary')}}" wx:if="{{item.change !== null}}">
              {{item.change > 0 ? '↑' : (item.change < 0 ? '↓' : '—')}} {{item.change !== 0 ? Math.abs(item.change).toFixed(1) : ''}}
            </view>
          </view>
        </view>
        
        <view class="entry-actions">
          <button class="btn-delete" bindtap="deleteEntry" data-id="{{item.id}}">
            <text>🗑️ 删除</text>
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{entries.length === 0}}">
    <view class="empty-icon">⚖️</view>
    <text class="empty-title">暂无记录</text>
    <text class="empty-desc">去记录页添加您的第一条体重记录吧</text>
    <button class="btn-primary" bindtap="goToRecord">去记录</button>
  </view>

  <!-- 清空所有 -->
  <view class="card" wx:if="{{entries.length > 0}}">
    <button class="btn-secondary btn-danger" bindtap="clearAll">
      <text>🗑️ 清空所有记录</text>
    </button>
  </view>
</view>