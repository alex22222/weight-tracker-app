/**pages/logs/logs.wxss**/
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 统计行 */
.stats-row {
  display: flex;
  justify-content: space-around;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  flex: 1;
}

.stat-number {
  font-size: 40rpx;
  font-weight: 700;
  color: #10b981;
}

.stat-desc {
  font-size: 24rpx;
  color: #64748b;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e2e8f0;
}

/* 列表样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 36rpx;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.entry-item {
  background: #f8fafc;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid #f1f5f9;
}

.entry-main {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.entry-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.entry-date {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.entry-note {
  font-size: 24rpx;
  color: #64748b;
  background: #e2e8f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  display: inline-block;
}

.entry-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.entry-weight {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.entry-weight .unit {
  font-size: 24rpx;
  color: #94a3b8;
  font-weight: 500;
}

.entry-change {
  font-size: 24rpx;
  font-weight: 600;
}

.entry-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 2rpx solid #e2e8f0;
  display: flex;
  justify-content: flex-end;
}

.btn-delete {
  background: #fee2e2;
  color: #ef4444;
  border: none;
  border-radius: 12rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.btn-delete::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 28rpx;
  color: #64748b;
  margin-bottom: 40rpx;
}

/* 危险按钮 */
.btn-danger {
  color: #ef4444 !important;
  border-color: #fecaca !important;
}

.btn-danger:active {
  background: #fee2e2 !important;
}