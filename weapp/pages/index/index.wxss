/**pages/index/index.wxss**/
.container {
  padding: 20rpx;
  padding-bottom: 40rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #34d399 0%, #14b8a6 100%);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 4rpx 12rpx rgba(16, 185, 129, 0.3);
}

.header-title {
  display: flex;
  flex-direction: column;
}

.title-main {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.title-sub {
  font-size: 22rpx;
  color: #10b981;
  margin-top: 4rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #10b981;
  background: #d1fae5;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

.header-btn {
  width: 64rpx;
  height: 64rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.header-btn:active {
  background: #e2e8f0;
}

.logout-btn:active {
  background: #fee2e2;
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stat-card {
  background: white;
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.stat-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.stat-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon {
  font-size: 28rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
}

.stat-value-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}

.stat-unit {
  font-size: 24rpx;
  color: #94a3b8;
}

.stat-hint {
  font-size: 22rpx;
  margin-top: 8rpx;
}

/* 表单样式 */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.title-icon {
  font-size: 36rpx;
}

.form-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.form-item {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.form-item-full {
  grid-column: span 2;
}

.form-label {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.input {
  background: #f1f5f9;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  font-size: 30rpx;
  color: #1e293b;
  border: 2rpx solid transparent;
}

.input:focus {
  border-color: #10b981;
}

.picker-input {
  display: flex;
  align-items: center;
}

/* 图表容器 */
.chart-container {
  width: 100%;
  height: 400rpx;
  margin-top: 20rpx;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .stats-grid {
    grid-template-columns: 1fr;
  }
  
  .form-grid {
    grid-template-columns: 1fr;
  }
  
  .form-item-full {
    grid-column: span 1;
  }
}