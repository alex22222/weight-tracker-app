/* pages/channel/detail.wxss */

/* 频道头部卡片 */
.channel-header-card {
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  color: white;
}

.channel-title-section {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.channel-name-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.channel-name {
  font-size: 40rpx;
  font-weight: 700;
}

.channel-status {
  font-size: 22rpx;
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.channel-actions {
  display: flex;
  gap: 12rpx;
  margin-left: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 12rpx 24rpx;
  border-radius: 12rpx;
  font-weight: 500;
}

.action-btn.primary {
  background: rgba(255,255,255,0.9);
  color: #10b981;
}

.action-btn.danger {
  background: rgba(255,255,255,0.2);
  color: white;
}

.channel-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 20rpx;
  line-height: 1.5;
}

.channel-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
}

.meta-icon {
  margin-right: 8rpx;
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.info-card {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 16rpx;
}

/* 规则列表 */
.rules-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.rule-tag {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #475569;
}

.rule-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

/* 进度卡片 */
.progress-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.progress-ratio {
  font-size: 32rpx;
  font-weight: 700;
  color: #10b981;
}

.progress-bar {
  height: 16rpx;
  background: #f1f5f9;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #34d399, #10b981);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-hint {
  font-size: 24rpx;
  color: #64748b;
}

/* 快捷操作栏 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.action-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.action-icon.checkin {
  background: linear-gradient(135deg, #34d399, #10b981);
}

.action-icon.invite {
  background: linear-gradient(135deg, #60a5fa, #3b82f6);
}

.action-icon.leave {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
}

.action-icon.comment {
  background: linear-gradient(135deg, #a78bfa, #8b5cf6);
}

.action-label {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

/* 标签页 */
.tab-bar {
  display: flex;
  background: white;
  border-radius: 16rpx;
  padding: 8rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #64748b;
  position: relative;
}

.tab-item.active {
  color: #10b981;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 8rpx;
  width: 48rpx;
  height: 4rpx;
  background: #10b981;
  border-radius: 2rpx;
}

/* 区块内容 */
.tab-content {
  min-height: 400rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 20rpx;
}

/* 成员列表 */
.member-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
}

.member-item {
  display: flex;
  align-items: center;
  background: #f8fafc;
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
}

.member-avatar {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: white;
  margin-right: 16rpx;
}

.member-info {
  display: flex;
  flex-direction: column;
}

.member-name {
  font-size: 28rpx;
  color: #475569;
  font-weight: 500;
}

.member-role {
  font-size: 20rpx;
  color: #10b981;
  background: #d1fae5;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

/* 打卡记录 */
.checkin-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.checkin-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.checkin-item:last-child {
  border-bottom: none;
}

.checkin-left {
  display: flex;
  align-items: center;
}

.checkin-avatar {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: white;
  margin-right: 20rpx;
}

.checkin-info {
  display: flex;
  flex-direction: column;
}

.checkin-user {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.checkin-date {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.checkin-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.checkin-duration {
  font-size: 28rpx;
  color: #10b981;
  font-weight: 600;
}

.checkin-note {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 评论区域 */
.comment-input-section {
  display: flex;
  gap: 16rpx;
  background: white;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.comment-input {
  flex: 1;
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
}

.send-btn {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: white;
  padding: 20rpx 32rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.send-btn.disabled {
  opacity: 0.6;
}

.comment-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.comment-item {
  display: flex;
  padding: 28rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: white;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.comment-body {
  flex: 1;
}

.comment-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.comment-user {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.comment-time {
  font-size: 22rpx;
  color: #94a3b8;
}

.comment-content {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.5;
}

.comment-actions {
  margin-top: 12rpx;
}

.comment-delete {
  font-size: 24rpx;
  color: #ef4444;
}

/* 请假区域 */
.leave-stats {
  display: flex;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.leave-stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-right: 2rpx solid #f1f5f9;
}

.leave-stats-item:last-child {
  border-right: none;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #10b981;
}

.stats-label {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.btn-leave {
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.leave-disabled {
  background: #f1f5f9;
  color: #94a3b8;
  border-radius: 16rpx;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  margin-bottom: 24rpx;
}

.leave-list {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.leave-item {
  padding: 28rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.leave-item:last-child {
  border-bottom: none;
}

.leave-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.leave-user {
  display: flex;
  align-items: center;
}

.leave-avatar {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  color: white;
  margin-right: 16rpx;
}

.leave-status {
  font-size: 22rpx;
  color: white;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.leave-dates {
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 8rpx;
}

.leave-reason {
  font-size: 26rpx;
  color: #64748b;
  background: #f8fafc;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}

.leave-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
}

.approve-btn, .reject-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
  text-align: center;
}

.approve-btn {
  background: #d1fae5;
  color: #059669;
}

.reject-btn {
  background: #fee2e2;
  color: #dc2626;
}

.leave-warning {
  background: #fef3c7;
  padding: 20rpx;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.leave-warning text {
  font-size: 26rpx;
  color: #92400e;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
  text-align: center;
  background: white;
  border-radius: 20rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 弹窗 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 24rpx;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 36rpx;
  color: #94a3b8;
  padding: 10rpx;
}

.modal-body {
  padding: 30rpx;
  overflow-y: auto;
  max-height: 60vh;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  padding: 30rpx;
  border-top: 2rpx solid #f1f5f9;
}

/* 表单 */
.form-item {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #475569;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-hint {
  display: block;
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 8rpx;
}

.input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #1e293b;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-input::after {
  content: '▼';
  font-size: 20rpx;
  color: #94a3b8;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 24rpx 0;
  font-size: 28rpx;
  font-weight: 500;
}

.flex-1 {
  flex: 1;
}

/* 好友列表 */
.friend-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.friend-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  border: 2rpx solid #e2e8f0;
}

.friend-item.selected {
  border-color: #10b981;
  background: #f0fdf4;
}

.friend-avatar {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: white;
  margin-right: 20rpx;
}

.friend-name {
  flex: 1;
  font-size: 28rpx;
  color: #475569;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: white;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #10b981;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #64748b;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

/* 图片上传 */
.image-upload {
  margin-top: 16rpx;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #cbd5e1;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #f8fafc;
}

.upload-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #64748b;
}

.image-preview {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.delete-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ef4444;
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

/* 打卡记录图片 */
.checkin-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-top: 12rpx;
}
