/* pages/channel/channel.wxss */

/* 头部 - 更紧凑 */
.header-section {
  display: flex;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #34d399, #10b981);
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.header-icon {
  font-size: 48rpx;
  margin-right: 16rpx;
}

.header-content {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: white;
}

.header-subtitle {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.9);
  margin-top: 4rpx;
}

/* 操作栏 - 更紧凑 */
.action-bar {
  margin-bottom: 20rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #34d399, #10b981);
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary[disabled] {
  opacity: 0.6;
}

.btn-secondary {
  background: #f1f5f9;
  color: #475569;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 20rpx 0;
  font-size: 28rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 区块 - 更紧凑 */
.section {
  margin-bottom: 24rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
  margin-bottom: 12rpx;
}

.title-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

/* 频道卡片 - 更紧凑 */
.channel-card {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  border: 2rpx solid #f1f5f9;
}

.channel-card.active {
  border: 2rpx solid #10b981;
  background: linear-gradient(135deg, #f0fdf4, white);
}

.channel-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.channel-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  flex: 1;
}

.channel-status {
  font-size: 20rpx;
  color: white;
  padding: 4rpx 12rpx;
  border-radius: 16rpx;
  font-weight: 500;
}

.channel-desc {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  line-height: 1.4;
}

/* 信息行 - 合并显示更紧凑 */
.channel-info {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 16rpx;
}

.info-item {
  font-size: 22rpx;
  color: #94a3b8;
}

.channel-rules {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 2rpx solid #f1f5f9;
}

.rule-tag {
  font-size: 20rpx;
  color: #10b981;
  background: #d1fae5;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 空状态 - 更紧凑 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 8rpx;
}

.empty-subtext {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 弹窗 - 更紧凑 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.modal-content {
  background: white;
  border-radius: 20rpx;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 2rpx solid #f1f5f9;
}

.modal-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 32rpx;
  color: #94a3b8;
  padding: 8rpx;
}

.modal-body {
  padding: 20rpx 24rpx;
  overflow-y: auto;
  max-height: 60vh;
}

.modal-footer {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  border-top: 2rpx solid #f1f5f9;
}

/* 表单 - 更紧凑 */
.form-item {
  margin-bottom: 16rpx;
}

.form-row {
  display: flex;
  gap: 16rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.form-hint {
  display: block;
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.input {
  background: #f8fafc;
  border: 2rpx solid #e2e8f0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 26rpx;
  color: #1e293b;
}

.picker-input {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.picker-input::after {
  content: '▼';
  font-size: 18rpx;
  color: #94a3b8;
}

.flex-1 {
  flex: 1;
}

/* 工具类 end */
